# 스폰지 노우비 · Sponzey Knowbee — 환경변수 설정 예시
# 이 파일을 .env 로 복사한 후 값을 채우세요.
# cp .env.example .env

# ─── Telegram 봇 (Phase 002) ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456789:AAF...
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# ─── MQTT 브로커 (내장 Aedes) ─────────────────────────
# KNOWBEE_MQTT_ENABLED=false
# KNOWBEE_MQTT_HOST=0.0.0.0
# KNOWBEE_MQTT_PORT=1883
# KNOWBEE_MQTT_USERNAME=knowbee
# KNOWBEE_MQTT_PASSWORD=change-me
# KNOWBEE_MQTT_ALLOW_ANONYMOUS=false

# ─── WebUI (Phase 006) ────────────────────────────────
# KNOWBEE_WEBUI_SECRET=your-secret-here

# ─── 경로 오버라이드 ───────────────────────────────────
# KNOWBEE_STATE_DIR=/custom/path/.knowbee
# KNOWBEE_CONFIG=/custom/path/config.json5

# ─── 로그 ─────────────────────────────────────────────
# KNOWBEE_LOG_LEVEL=debug    # debug | info | warn | error
# KNOWBEE_NO_COLOR=1
